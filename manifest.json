{
  "manifest_version": 3,
  "name": "Open Brain — Today",
  "short_name": "Open Brain",
  "version": "1.0.3",
  "description": "Новая вкладка Chrome: 3 задачи на сегодня из Open Brain + дневной бриф от Claude.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_page": "options.html",
  "permissions": ["storage"],
  "host_permissions": ["https://*.supabase.co/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
